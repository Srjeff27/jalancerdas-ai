# =============================================================================
# JalanCerdas AI - Environment Variables
# Copy this file to .env and modify as needed
# =============================================================================

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://jalancerdas:jalancerdas_secret@postgres:5432/jalancerdas_db
POSTGRES_USER=jalancerdas
POSTGRES_PASSWORD=jalancerdas_secret
POSTGRES_DB=jalancerdas_db

# MinIO Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=road-detections
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-key-in-production

# API / Dashboard URLs
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
